{
  "name": "spam-detection-backend",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:sync": "node -e \"require('./models').sequelize.sync({force:false}).then(()=>process.exit(0))\"",
    "db:reset": "node -e \"require('./models').sequelize.sync({force:true}).then(()=>process.exit(0))\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sqlite3": "^6.0.1"
  }
}
